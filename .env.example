# ============================================================
# DXF-kimi25 — environment variables example
# Copy to .env and fill in real values (never commit .env)
# ============================================================

# ─── Supabase ────────────────────────────────────────────────
# Project URL from: Supabase Dashboard → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Service-role secret key (server-side only, never expose to browser)
# From: Supabase Dashboard → Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Table / bucket names (optional — defaults shown below)
SUPABASE_WORKSPACE_CATALOGS_TABLE=workspace_catalogs
SUPABASE_WORKSPACE_FILES_TABLE=workspace_files
SUPABASE_DXF_FILES_BUCKET=dxf-files
SUPABASE_SHARED_SHEETS_TABLE=shared_sheets

# ─── Telegram bot ────────────────────────────────────────────
# Token from @BotFather
TELEGRAM_BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Comma-separated list of allowed origins for CORS (optional)
# Example: https://your-frontend.netlify.app,https://your-domain.com
ALLOWED_ORIGINS=

# ─── API service ─────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ─── UI app (Vite build-time env) ────────────────────────────
# Base URL of the api-service visible from the browser
VITE_API_BASE=https://your-api.example.com
