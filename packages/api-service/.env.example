# API port
PORT=3000

# Comma-separated list of allowed CORS origins
# Example:
# ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,https://your-ui.vercel.app
ALLOWED_ORIGINS=

# Supabase (persistent storage for shared sheet hashes)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Optional (defaults to shared_sheets)
SUPABASE_SHARED_SHEETS_TABLE=shared_sheets

# Telegram webhook mode
TELEGRAM_BOT_TOKEN=
# Public HTTPS endpoint for Telegram setWebhook (optional if passing body.url to /api/telegram/webhook/register)
TELEGRAM_WEBHOOK_URL=
# Optional secret to validate x-telegram-bot-api-secret-token header
TELEGRAM_WEBHOOK_SECRET=
# Auto-register webhook on startup when TELEGRAM_BOT_TOKEN and TELEGRAM_WEBHOOK_URL are set
# Default behavior: true on Vercel/production, false in local runtime
TELEGRAM_WEBHOOK_AUTO_REGISTER=true
