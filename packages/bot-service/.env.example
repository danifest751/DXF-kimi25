# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Long polling timeout in seconds
TELEGRAM_POLL_TIMEOUT_SEC=30

# Supabase (required if bot runs as separate process and should resolve hashes)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Optional (defaults to shared_sheets)
SUPABASE_SHARED_SHEETS_TABLE=shared_sheets
