{
  "name": "dxf-viewer-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "DXF Viewer monorepo - core + api + ui + pricing + bot + next.js app",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "dev:legacy": "npm run dev -w @dxf-viewer/ui-app",
    "dev:api": "npm run dev -w @dxf-viewer/api-service",
    "dev:bot": "npm run dev -w @dxf-viewer/bot-service",
    "dev:all": "concurrently -k -n api,ui -c blue,green \"npm run dev:api\" \"npm run dev\"",
    "typecheck": "npm run typecheck -ws --if-present",
    "build:packages": "npm run build -w @dxf-viewer/core-engine && npm run build -w @dxf-viewer/api-service && npm run build -w @dxf-viewer/pricing && npm run build -w @dxf-viewer/bot-service && npm run build -w @dxf-viewer/ui-app",
    "build:core": "npm run build -w @dxf-viewer/core-engine",
    "build:api": "npm run build -w @dxf-viewer/api-service",
    "build:ui": "npm run build -w @dxf-viewer/ui-app",
    "start:bot": "npm run start -w @dxf-viewer/bot-service",
    "test": "vitest run",
    "test:ui": "vitest run tests/ui",
    "test:set-builder": "vitest run tests/ui/set-builder-state.test.ts tests/ui/set-builder-mock-nesting.test.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.4",
    "@radix-ui/react-scroll-area": "^1.2.9",
    "@radix-ui/react-select": "^2.1.14",
    "@radix-ui/react-separator": "^1.1.4",
    "@radix-ui/react-slot": "^1.2.2",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.12",
    "@radix-ui/react-tooltip": "^1.1.14",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.513.0",
    "next": "^15.3.0",
    "next-themes": "^0.4.6",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-dropzone": "^14.3.8",
    "recharts": "^2.15.3",
    "sonner": "^2.0.3",
    "tailwind-merge": "^3.3.0",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^22.15.29",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "postcss": "^8.5.4",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
