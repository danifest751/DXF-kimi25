{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist-node",
    "rootDir": "./src",
    "lib": ["ES2022"],
    "types": ["node"],
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": [
    "src/index.ts",
    "src/config.ts",
    "src/dxf/**/*",
    "src/geometry/**/*",
    "src/normalize/**/*",
    "src/cutting/**/*",
    "src/nesting/**/*",
    "src/export/**/*",
    "src/types/**/*"
  ],
  "exclude": ["node_modules", "dist", "dist-node", "src/**/*.test.ts", "src/render/**/*", "src/workers/**/*"]
}
