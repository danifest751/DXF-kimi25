# Base URL of API service
# Local dev: keep empty to use Vite proxy (/api -> http://localhost:3000)
# Production: set full API URL, e.g. https://dxf-api.example.com
VITE_API_BASE=

# Sentry DSN (optional, leave empty to disable)
VITE_SENTRY_DSN=
# Git commit SHA or tag for Sentry release tracking
VITE_SENTRY_RELEASE=
